<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="view_sale_excel_import_form" model="ir.ui.view">
        <field name="name">sale.excel.import.form</field>
        <field name="model">sale.excel.import</field>
        <field name="arch" type="xml">
            <form string="Crear venta desde Excel">

                <group>
                    <field name="filename" invisible="1"/>
                    <field name="file" filename="filename" widget="binary"/>
                </group>

                <group>
                    <field name="partner_id" options="{'no_create':True,'no_open':True}"/>
                    <field name="user_id" options="{'no_create':True,'no_open':True}"/>
                    <field name="client_order_ref"/>
                    <field name="tag_ids" options="{'no_create':True,'no_open':True}" widget="many2many_tags"/>
                </group>

                <notebook>
                    <page string="Resultados">
                        <field name="preview_html" widget="html" readonly="1" force_save="1" nolabel="1"/>
                    </page>
                </notebook>

                <footer>
                    <button name="action_download_template"
                            type="object"
                            string="Descargar plantilla"
                            class="btn-secondary"/>
                    <button name="action_confirm" type="object" string="Confirmar" class="btn-success"/>
                </footer>

            </form>
        </field>
    </record>

    <record id="action_sale_excel_import" model="ir.actions.act_window">
        <field name="name">Crear venta desde Excel</field>
        <field name="res_model">sale.excel.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_sale_excel_import"
              name="Crear venta desde Excel"
              parent="sale.sale_order_menu"
              sequence="30"
              action="action_sale_excel_import"/>

</odoo>